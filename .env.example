BOT_TOKEN=123456:ABC-Your-Telegram-Bot-Token
# 主用 RPC。也支持多个 RPC 用逗号分隔（首个为主用，其余自动作为备用）。
BSC_RPC_URL=https://your-bsc-rpc-endpoint
# 额外的备用 RPC 列表，逗号分隔（可选）。任一主/备 RPC 失败时会自动切换。
# 例：BSC_RPC_URLS=https://bsc-dataseed1.binance.org,https://bsc-dataseed2.binance.org
BSC_RPC_URLS=
DB_PATH=/data/watchers.db
SCAN_INTERVAL=5
CONFIRMATIONS=2
BLOCK_CHUNK=200
DEFAULT_LOOKBACK=0
LOG_LEVEL=INFO
